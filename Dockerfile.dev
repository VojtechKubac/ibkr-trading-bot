FROM python:3.12-slim

ARG USERNAME=agent
ARG USER_UID=1000
ARG USER_GID=1000

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PIP_DISABLE_PIP_VERSION_CHECK=1

# System packages + Node.js 22 (required for Claude Code CLI)
RUN apt-get update \
    && apt-get install -y --no-install-recommends git bash ca-certificates curl \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && ln -sf /usr/bin/node /usr/local/bin/node \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Cursor agent CLI — expose binary for all users
RUN curl -fsSL https://cursor.com/install | bash \
    && ln -sf /root/.local/bin/cursor-agent /usr/local/bin/cursor-agent \
    && chmod 755 /root /root/.local /root/.local/bin \
    && chmod -R a+rx /root/.local/share/cursor-agent

# Git system config: identity and global hooks directory
# --system applies to all users regardless of HOME; must run as root before USER switch
RUN git config --system user.name "ticket-agent" \
    && git config --system user.email "ticket-agent@noreply" \
    && git config --system core.hooksPath /git-hooks

# Pre-push hook: block any push to main or master
RUN mkdir -p /git-hooks \
    && printf '#!/bin/sh\nwhile read local_ref local_sha remote_ref remote_sha; do\n  case "$remote_ref" in\n    refs/heads/main|refs/heads/master)\n      echo "ERROR: pushing to main/master is blocked in ticket containers." >&2\n      exit 1\n      ;;\n  esac\ndone\nexit 0\n' > /git-hooks/pre-push \
    && chmod +x /git-hooks/pre-push

RUN groupadd --gid "${USER_GID}" "${USERNAME}" \
    && useradd --uid "${USER_UID}" --gid "${USER_GID}" --create-home --shell /bin/bash "${USERNAME}"

WORKDIR /workspace

COPY requirements.txt requirements-dev.txt /tmp/deps/
RUN python -m pip install --upgrade pip \
    && python -m pip install -r /tmp/deps/requirements.txt -r /tmp/deps/requirements-dev.txt

USER ${USERNAME}

CMD ["/bin/bash"]
