# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# ---------------------------------------------------------------------------
# IBKR connection
# ---------------------------------------------------------------------------
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497          # 7497 = paper trading, 7496 = live
# IBKR_CLIENT_ID=1
# IBKR_ACCOUNT=           # leave blank to use IBKR default account
# IBKR_CURRENCY=EUR
# IBKR_TIMEOUT=4          # seconds to wait for TWS/IB Gateway connection

# ---------------------------------------------------------------------------
# Weekly runner (run_weekly.py)
# ---------------------------------------------------------------------------
# WEEKLY_SYMBOLS=vwce           # comma-separated asset keys, e.g. vwce,spy
# DRYRUN=true                   # true = log only, false = allow order execution
# IBKR_ENABLE=false             # must be true (with DRYRUN=false) to place real orders
# SIGNAL_STRATEGY=simple        # simple = Phase 1 MA rules | weighted = composite scoring
# STOP_LOSS_PCT=0.15            # sell if price drops >15% below entry
# POSITION_ALLOCATION_PCT=0.25  # fraction of PORTFOLIO_VALUE to invest per signal
# PORTFOLIO_VALUE=10000         # total portfolio value used for position sizing

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# DB_PATH=trading_bot.db

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
# LOG_FILE=               # leave blank to log to stdout only
